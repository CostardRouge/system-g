---
/**
 * Layout de base : squelette HTML, métadonnées, en-tête et pied de page.
 * Toutes les pages s'appuient dessus.
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo, { type PageType } from '../components/Seo.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  /** Nature de la page — pilote og:type et le nœud schema.org. */
  type?: PageType;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title, description, type = 'website' } = Astro.props;
const pageTitle = title ? `${title} — ${t('site.title')}` : `${t('site.title')} — ${t('site.tagline')}`;
const pageDescription = description ?? t('site.description');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={t('bio.title')} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#7a2e2e" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon-32.png`} sizes="32x32" type="image/png" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon-16.png`} sizes="16x16" type="image/png" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} sizes="48x48" />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    <link rel="manifest" href={`${import.meta.env.BASE_URL}site.webmanifest`} />

    <Seo pageTitle={pageTitle} pageDescription={pageDescription} type={type} />
    <SchemaOrg pageTitle={pageTitle} pageDescription={pageDescription} type={type} />
  </head>
  <body>
    <a class="skip-link" href="#main">{t('nav.skipToContent')}</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
