---
/**
 * Contenu générique « rubrique en préparation ».
 * Utilisé pour Littérature, Théorie et Player en attendant leurs contenus.
 */
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';

interface Props {
  titleKey: 'nav.literature' | 'nav.theory' | 'nav.player';
}

const { titleKey } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="container">
  <header class="bio-header">
    <p class="overline overline--accent">{t('site.title')}</p>
    <h1>{t(titleKey)}</h1>
  </header>

  <div class="wip">
    <p class="wip__glyph" aria-hidden="true">♮</p>
    <p class="lede">{t('page.wip')}</p>
    <p>{t('page.wip.detail')}</p>
    <p>
      <a class="text-link" href={localizedPath('/', lang)}>← {t('back.home')}</a>
    </p>
  </div>
</div>
