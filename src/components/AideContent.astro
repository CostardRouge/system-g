---
/**
 * Rendu de la page d'aide du player. Parcourt les blocs typés du module
 * de contenu (src/content/aide.ts) et résout les cibles internes
 * ('player', 'theory', 'theoryIntro'). Construit aussi un petit sommaire
 * à partir des titres de section.
 */
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import { aide, type AideLink } from '../content/aide';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const doc = aide[lang] ?? aide.fr;

const targets: Record<AideLink, string> = {
  player: localizedPath('/player', lang),
  theory: localizedPath('/theorie', lang),
  theoryIntro: localizedPath('/theorie/introduction', lang),
};

const toc = doc.blocks.filter((b): b is Extract<typeof b, { t: 'h2' }> => b.t === 'h2');
---

<div class="container">
  <header class="bio-header">
    <p class="overline overline--accent">{doc.overline}</p>
    <h1>{doc.title}</h1>
    <p class="hero__subtitle">{doc.subtitle}</p>
  </header>

  <aside class="preliminary" role="note">
    <p>{doc.aside}</p>
  </aside>

  {
    toc.length > 0 && (
      <nav class="aide-toc" aria-label={doc.title}>
        <ol>
          {toc.map((b) => (
            <li>
              <a href={`#${b.id}`}>{b.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )
  }

  <article class="essay aide">
    {
      doc.blocks.map((block) => {
        switch (block.t) {
          case 'h2':
            return <h2 id={block.id}>{block.text}</h2>;
          case 'p':
            return <p>{block.text}</p>;
          case 'list':
            return (
              <ul class="lozenge-list">
                {block.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            );
          case 'steps':
            return (
              <ol class="aide-steps">
                {block.items.map((item) => (
                  <li>
                    <span class="aide-steps__title">{item.title}</span>
                    <span class="aide-steps__text">{item.text}</span>
                  </li>
                ))}
              </ol>
            );
          case 'try':
            return (
              <ul class="aide-try">
                {block.items.map((item) => (
                  <li>
                    <span class="aide-try__title">{item.title}</span>
                    <span class="aide-try__text">{item.text}</span>
                  </li>
                ))}
              </ul>
            );
          case 'keys':
            return (
              <div class="aide-keys">
                {block.caption && <p class="aide-keys__caption">{block.caption}</p>}
                <dl>
                  {block.rows.map((row) => (
                    <div class="aide-keys__row">
                      <dt>
                        <code>{row.k}</code>
                      </dt>
                      <dd>{row.v}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            );
          case 'callout':
            return (
              <aside class="callout">
                <p>{block.text}</p>
                {block.links && block.links.length > 0 && (
                  <p class="callout__links">
                    {block.links.map((link, i) => (
                      <>
                        {i > 0 && <span class="callout__sep">·</span>}
                        <a class="text-link" href={targets[link.to]}>
                          {link.label}
                        </a>
                      </>
                    ))}
                  </p>
                )}
              </aside>
            );
          default:
            return null;
        }
      })
    }
  </article>

  <p class="aide-back">
    <a class="text-link" href={targets.player}>← {t('aide.backToPlayer')}</a>
  </p>
</div>

<style>
  .aide-toc {
    margin: 1.5rem 0 2.5rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius);
    background: var(--paper-2);
  }

  .aide-toc ol {
    margin: 0;
    padding-left: 1.2rem;
    columns: 2;
    column-gap: 2rem;
    font-family: var(--sans);
    font-size: 0.9rem;
  }

  .aide-toc li {
    margin: 0.15rem 0;
    break-inside: avoid;
  }

  .aide-toc a {
    color: var(--ink-soft);
    text-decoration: none;
  }

  .aide-toc a:hover {
    color: var(--accent-deep);
    text-decoration: underline;
  }

  .aide-steps {
    list-style: none;
    counter-reset: aide-step;
    margin: 1.2rem 0;
    padding: 0;
  }

  .aide-steps li {
    counter-increment: aide-step;
    position: relative;
    padding: 0.6rem 0 0.6rem 2.6rem;
    border-top: 1px solid var(--paper-edge);
  }

  .aide-steps li::before {
    content: counter(aide-step);
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 1.8rem;
    height: 1.8rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--accent-deep);
    color: var(--paper);
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .aide-steps__title,
  .aide-try__title {
    display: block;
    font-family: var(--sans);
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.15rem;
  }

  .aide-steps__text,
  .aide-try__text {
    color: var(--ink-soft);
  }

  .aide-try {
    list-style: none;
    margin: 1.2rem 0;
    padding: 0;
    display: grid;
    gap: 0.8rem;
  }

  .aide-try li {
    padding: 0.8rem 1rem;
    border: 1px solid var(--paper-edge);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    background: var(--paper-2);
  }

  .aide-keys {
    margin: 1.2rem 0;
  }

  .aide-keys__caption {
    font-family: var(--sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-faint);
    margin: 0 0 0.4rem;
  }

  .aide-keys dl {
    margin: 0;
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .aide-keys__row {
    display: grid;
    grid-template-columns: minmax(9rem, 14rem) 1fr;
    gap: 0.5rem 1rem;
    padding: 0.5rem 0.9rem;
    border-top: 1px solid var(--paper-edge);
  }

  .aide-keys__row:first-child {
    border-top: none;
  }

  .aide-keys dt {
    margin: 0;
  }

  .aide-keys dt code {
    font-family: var(--mono, ui-monospace, monospace);
    font-size: 0.82rem;
    color: var(--accent-deep);
    background: var(--paper);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    border: 1px solid var(--paper-edge);
    white-space: nowrap;
  }

  .aide-keys dd {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  .aide-back {
    margin: 2.5rem 0 1rem;
  }

  @media (max-width: 34rem) {
    .aide-toc ol {
      columns: 1;
    }
    .aide-keys__row {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
  }
</style>
